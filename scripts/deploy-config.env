# ============================================
# 标准物质管理系统 - 部署配置文件
# ============================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=reference_material_management
DB_USER=root
DB_PASS=xjYY3687!

# Git配置
GIT_REPO=https://github.com/zmmly/reference_material_management.git
GIT_BRANCH=main

# 部署配置
DEPLOY_DIR=/opt/reference-material_management
BACKUP_DIR=/opt/reference_material_management_backups

# 服务配置
PROJECT_NAME=reference-material-management
NGINX_PORT=80
FRONTEND_PORT=3002
BACKEND_PORT=8080

# JVM配置
JAVA_OPTS="-Xms512m -Xmx1024m -XX:+UseG1GC"

# 服务运行用户（可选，默认root）
SERVICE_USER=root

# 邮件通知配置（可选）
NOTIFICATION_EMAIL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 是否启用自动备份
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点
